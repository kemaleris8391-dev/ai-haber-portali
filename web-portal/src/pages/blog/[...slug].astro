---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (date: Date) => {
  return date.toLocaleDateString('tr-TR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
};
---

<Layout 
  title={post.data.title} 
  description={post.data.description} 
  image={post.data.heroImage}
  type="article"
  articleData={{
    pubDate: post.data.pubDate,
    dateModified: post.data.dateModified || post.data.pubDate,
    category: post.data.category
  }}
>
  <article class="news-detail-container" id={`article-${post.slug}`}>
    <!-- Geri Dön Butonu -->
    <a href="/" class="back-link" id="back-to-home-btn">&larr; Geri Dön</a>

    <!-- Üst Başlık & Bilgiler -->
    <header class="detail-header">
      <div class="category-meta">
        <span class={`badge-category badge-${post.data.category}`}>{post.data.category}</span>
        <time datetime={post.data.pubDate.toISOString()} class="date-text">{formatDate(post.data.pubDate)}</time>
      </div>
      <h1 class="detail-title">{post.data.title}</h1>
      <p class="detail-description">{post.data.description}</p>
    </header>

    <!-- Büyük Kapak Görseli -->
    {post.data.heroImage && (
      <div class="detail-image-wrapper">
        <img 
          src={post.data.heroImage} 
          alt={post.data.title} 
          class="detail-image" 
          width="1200" 
          height="675" 
          loading="eager" 
          fetchpriority="high"
        />
      </div>
    )}

    <!-- Makale Gövdesi ve Kaynak -->
    <div class="detail-body-container">
      <div class="prose-content">
        <Content />
      </div>

      <!-- Yapay Zeka İçerik Açıklaması (AI Content Disclosure) -->
      <div class="ai-disclosure-box" id="ai-disclosure">
        <span class="ai-icon">⚙️</span>
        <p><strong>Yapay Zeka Beyanı:</strong> Bu haber içeriği, yapay zeka otomasyon sistemleri tarafından derlenmiş ve editoryal kontrol sonrasında yayına alınmıştır.</p>
      </div>

      <!-- Yazar Künye Kartı (Author Bio Box) -->
      <div class="author-bio-card glass-card" id="author-bio">
        <div class="author-bio-avatar">🤖</div>
        <div class="author-bio-info">
          <h4>Yazar: <a href="/yazar/editoryal-ekip">Teknoloji Editoryal Ekibi</a></h4>
          <p>AIHaberler bünyesinde teknoloji, donanım, bilim, gaming ve sinema dünyasındaki gelişmeleri otonom tarayarak Türkçe raporlar hazırlayan yapay zeka ajan editör grubu.</p>
        </div>
      </div>

      <!-- Kaynak ve Paylaşım -->
      <footer class="detail-footer">
        {post.data.sourceName && post.data.sourceUrl && (
          <div class="source-info-card glass-card">
            <span>Bu haber yapay zeka tarafından <strong>{post.data.sourceName}</strong> üzerinden derlenmiştir.</span>
            <a href={post.data.sourceUrl} target="_blank" rel="noopener noreferrer" class="btn-neon" id="original-source-btn">
              Orijinal Kaynağa Git &nearr;
            </a>
          </div>
        )}

        <!-- Etiketler -->
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="tags-container">
            <span class="tags-label">Etiketler:</span>
            {post.data.tags.map(tag => (
              <span class="tag-badge">#{tag}</span>
            ))}
          </div>
        )}
      </footer>
    </div>
  </article>
</Layout>

<style>
  .news-detail-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 1rem 0;
  }

  .back-link {
    color: var(--color-cyan);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: var(--transition-smooth);
    display: inline-block;
    margin-bottom: 2rem;
  }

  .back-link:hover {
    color: var(--color-purple);
    transform: translateX(-4px);
  }

  .category-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .date-text {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .detail-title {
    font-size: 3rem;
    line-height: 1.15;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, #ffffff 0%, #a1a1aa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .detail-description {
    font-size: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 2.5rem;
    border-left: 3px solid var(--color-cyan);
    padding-left: 1.5rem;
  }

  .detail-image-wrapper {
    width: 100%;
    height: 450px;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 3rem;
    border: 1px solid var(--border-color);
  }

  .detail-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Markdown İçerik Stilleri (Prose) */
  .prose-content {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #e4e4e7;
  }

  .prose-content :global(p) {
    margin-bottom: 1.75rem;
  }

  .prose-content :global(h2), .prose-content :global(h3) {
    margin: 2.5rem 0 1.25rem 0;
    line-height: 1.3;
  }

  .prose-content :global(h2) {
    font-size: 1.8rem;
    background: linear-gradient(135deg, #ffffff 0%, #d4d4d8 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .prose-content :global(h3) {
    font-size: 1.4rem;
  }

  .prose-content :global(ul), .prose-content :global(ol) {
    margin-bottom: 1.75rem;
    padding-left: 1.5rem;
  }

  .prose-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose-content :global(strong) {
    color: #ffffff;
    font-weight: 600;
  }

  .prose-content :global(a) {
    color: var(--color-cyan);
    text-decoration: none;
    border-bottom: 1px dashed var(--color-cyan);
    transition: var(--transition-smooth);
  }

  .prose-content :global(a:hover) {
    color: var(--color-purple);
    border-bottom-color: var(--color-purple);
  }

  /* Detail Footer & Source Card */
  .detail-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
  }

  .source-info-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2rem;
    margin-bottom: 2.5rem;
    gap: 1.5rem;
  }

  .source-info-card span {
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .tags-container {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .tags-label {
    font-size: 0.9rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .tag-badge {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-color);
    padding: 0.25rem 0.75rem;
    border-radius: 6px;
    font-size: 0.85rem;
    color: var(--text-secondary);
    transition: var(--transition-smooth);
  }

  .tag-badge:hover {
    background: rgba(139, 92, 246, 0.1);
    border-color: var(--color-purple);
    color: #ffffff;
  }

  /* AI Disclosure and Author Box */
  .ai-disclosure-box {
    display: flex;
    gap: 1rem;
    align-items: center;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 1rem 1.5rem;
    border-radius: 8px;
    margin: 2rem 0;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .ai-disclosure-box p {
    margin: 0;
  }

  .ai-icon {
    font-size: 1.25rem;
  }

  .author-bio-card {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem 2rem;
    align-items: center;
    margin-bottom: 3rem;
  }

  .author-bio-avatar {
    width: 60px;
    height: 60px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-color);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    flex-shrink: 0;
  }

  .author-bio-info h4 {
    font-size: 1.1rem;
    color: #ffffff;
    margin-bottom: 0.25rem;
  }

  .author-bio-info h4 a {
    color: var(--color-cyan);
    text-decoration: none;
    transition: var(--transition-smooth);
  }

  .author-bio-info h4 a:hover {
    color: var(--color-purple);
  }

  .author-bio-info p {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
  }

  @media (max-width: 768px) {
    .detail-title {
      font-size: 2.2rem;
    }
    
    .detail-image-wrapper {
      height: 300px;
    }

    .source-info-card {
      flex-direction: column;
      text-align: center;
      padding: 1.5rem;
    }

    .author-bio-card {
      flex-direction: column;
      text-align: center;
      padding: 1.5rem;
    }
  }
</style>
