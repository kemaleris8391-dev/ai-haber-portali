---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

export async function getStaticPaths({ paginate }) {
  const allPosts = await getCollection('blog');
  const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return paginate(sortedPosts, { pageSize: 13 });
}

const { page } = Astro.props;

// Öne çıkan haber (en son eklenen) sadece ilk sayfada gösterilir
const isFirstPage = page.currentPage === 1;
const heroPost = isFirstPage && page.data.length > 0 ? page.data[0] : null;
const gridPosts = isFirstPage ? page.data.slice(1) : page.data;

const formatDate = (date: Date) => {
  return date.toLocaleDateString('tr-TR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit'
  });
};
---

<Layout title="Ana Sayfa">
	<!-- Hero & Empty State Section -->
	{page.data.length === 0 && (
		<section class="hero-section">
			<div class="glass-card empty-state" id="empty-portal">
				<h2>Portala Hoş Geldiniz!</h2>
				<p>Şu anda yayında olan bir haber bulunmuyor. Otonom haber toplama scriptimizi çalıştırarak ilk haberleri çekebilirsiniz.</p>
				<div class="instructions">
					<code>run_pipeline.bat</code> dosyasını çift tıklayarak çalıştırın veya terminalde <code>python backend-scripts/main.py</code> komutunu girin.
				</div>
			</div>
		</section>
	)}

	{heroPost && (
		<section class="hero-section">
			<div class="glass-card hero-card glow-border" id="hero-news">
				<div class="hero-image-container">
					<img src={heroPost.data.heroImage} alt={heroPost.data.title} class="hero-image" width="1200" height="675" loading="eager" fetchpriority="high" />
					<div class="hero-category">
						<span class={`badge-category badge-${heroPost.data.category}`}>{heroPost.data.category}</span>
					</div>
				</div>
				<div class="hero-content">
					<div class="post-meta">
						<time datetime={heroPost.data.pubDate.toISOString()}>{formatDate(heroPost.data.pubDate)}</time>
						{heroPost.data.sourceName && (
							<span class="post-source">
								Kaynak: <a href={heroPost.data.sourceUrl} target="_blank" rel="noopener noreferrer">{heroPost.data.sourceName}</a>
							</span>
						)}
					</div>
					<h1 class="hero-title">{heroPost.data.title}</h1>
					<p class="hero-desc">{heroPost.data.description}</p>
					<a href={`/blog/${heroPost.id}`} class="btn-neon" id="read-hero-btn">Devamını Oku</a>
				</div>
			</div>
		</section>
	)}

	<!-- News Grid Section -->
	{gridPosts.length > 0 && (
		<section class="grid-section">
			<h2 class="section-title">Göz Atın</h2>
			<div class="news-grid">
				{gridPosts.map((post) => (
					<article class="glass-card news-card" id={`post-${post.id}`}>
						<div class="card-image-container">
							<img src={post.data.heroImage} alt={post.data.title} class="card-image" loading="lazy" width="600" height="338" />
							<span class={`badge-category badge-${post.data.category} card-badge`}>{post.data.category}</span>
						</div>
						<div class="card-content">
							<div class="post-meta">
								<time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
							</div>
							<h3 class="card-title">{post.data.title}</h3>
							<p class="card-desc">{post.data.description}</p>
							<a href={`/blog/${post.id}`} class="card-link" id={`link-${post.id}`}>Haber Detayı &rarr;</a>
						</div>
					</article>
				))}
			</div>

			<!-- Pagination Controls -->
			{page.lastPage > 1 && (
				<nav class="pagination-nav" aria-label="Sayfalama">
					{page.url.prev ? (
						<a href={page.url.prev} class="btn-neon pagination-btn">&larr; Önceki</a>
					) : (
						<span class="btn-neon pagination-btn disabled">&larr; Önceki</span>
					)}
					
					<span class="pagination-info">
						Sayfa {page.currentPage} / {page.lastPage}
					</span>
					
					{page.url.next ? (
						<a href={page.url.next} class="btn-neon pagination-btn">Sonraki &rarr;</a>
					) : (
						<span class="btn-neon pagination-btn disabled">Sonraki &rarr;</span>
					)}
				</nav>
			)}
		</section>
	)}
</Layout>

<style>
	.hero-section {
		margin-bottom: 4rem;
	}

	.hero-card {
		display: grid;
		grid-template-columns: 1.2fr 1fr;
		min-height: 480px;
	}

	.hero-image-container {
		position: relative;
		overflow: hidden;
		min-height: 300px;
	}

	.hero-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: var(--transition-smooth);
	}

	.hero-card:hover .hero-image {
		transform: scale(1.03);
	}

	.hero-category {
		position: absolute;
		top: 1.5rem;
		left: 1.5rem;
		z-index: 10;
	}

	.hero-content {
		padding: 3rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: flex-start;
		gap: 1.5rem;
	}

	.post-meta {
		display: flex;
		gap: 1.5rem;
		font-size: 0.85rem;
		color: var(--text-muted);
		align-items: center;
	}

	.post-source a {
		color: var(--color-cyan);
		text-decoration: none;
		transition: var(--transition-smooth);
	}

	.post-source a:hover {
		color: var(--color-purple);
	}

	.hero-title {
		font-size: 2.5rem;
		line-height: 1.2;
		background: linear-gradient(135deg, #ffffff 0%, #a1a1aa 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.hero-desc {
		color: var(--text-secondary);
		font-size: 1.1rem;
		line-height: 1.6;
	}

	/* Empty State */
	.empty-state {
		text-align: center;
		padding: 5rem 2rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
	}

	.empty-state h2 {
		font-size: 2rem;
		background: var(--gradient-primary);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.empty-state p {
		color: var(--text-secondary);
		max-width: 600px;
	}

	.instructions {
		background: rgba(0, 0, 0, 0.4);
		padding: 1rem 2rem;
		border-radius: 8px;
		border: 1px solid var(--border-color);
		color: var(--color-cyan);
		font-family: monospace;
		font-size: 0.95rem;
	}

	/* Grid Section */
	.section-title {
		font-size: 1.8rem;
		margin-bottom: 2rem;
		position: relative;
		display: inline-block;
	}

	.section-title::after {
		content: '';
		position: absolute;
		bottom: -8px;
		left: 0;
		width: 40px;
		height: 3px;
		background: var(--gradient-primary);
		border-radius: 2px;
	}

	.news-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
		gap: 2rem;
	}

	.news-card {
		display: flex;
		flex-direction: column;
		height: 100%;
	}

	.card-image-container {
		position: relative;
		height: 200px;
		overflow: hidden;
	}

	.card-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: var(--transition-smooth);
	}

	.news-card:hover .card-image {
		transform: scale(1.05);
	}

	.card-badge {
		position: absolute;
		top: 1rem;
		left: 1rem;
		z-index: 10;
	}

	.card-content {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		flex: 1;
	}

	.card-title {
		font-size: 1.3rem;
		line-height: 1.4;
		transition: var(--transition-smooth);
	}

	.news-card:hover .card-title {
		color: var(--color-purple);
	}

	.card-desc {
		color: var(--text-secondary);
		font-size: 0.95rem;
		line-height: 1.5;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
		flex: 1;
	}

	.card-link {
		color: var(--color-cyan);
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 600;
		transition: var(--transition-smooth);
		margin-top: auto;
		display: inline-flex;
		align-items: center;
	}

	.card-link:hover {
		color: var(--color-purple);
		transform: translateX(4px);
	}

	/* Pagination Styles */
	.pagination-nav {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 2rem;
		margin-top: 4rem;
		padding-top: 2rem;
		border-top: 1px solid var(--border-color);
	}

	.pagination-info {
		color: var(--text-secondary);
		font-weight: 500;
		font-size: 1.1rem;
	}

	.pagination-btn.disabled {
		opacity: 0.5;
		cursor: not-allowed;
		pointer-events: none;
	}

	@media (max-width: 900px) {
		.hero-card {
			grid-template-columns: 1fr;
		}
		
		.hero-content {
			padding: 2rem;
		}
	}
</style>
