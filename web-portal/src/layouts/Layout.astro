---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import Search from '../components/Search.astro';

interface Props {
	title: string;
	description?: string;
	image?: string;
	keywords?: string[];
	type?: 'website' | 'article';
	articleData?: {
		pubDate: Date;
		dateModified?: Date;
		category: string;
		author?: string;
	};
}

const {
	title,
	description = "Teknoloji, oyun, dizi ve film dünyasından en son haberler, fragmanlar ve yapay zeka analizleri.",
	image = "/images/default-news.png",
	keywords = ["teknoloji", "oyun", "dizi", "sinema", "haber"],
	type = "website",
	articleData
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || import.meta.env.PUBLIC_SITE_URL || 'https://aihaberler.web.app');
const siteName = import.meta.env.PUBLIC_BRAND_NAME || "AIHABERLER";
const adsenseClientId = import.meta.env.PUBLIC_ADSENSE_CLIENT_ID;

// Dynamic categories extraction
const allPosts = await getCollection('blog');
const activeCategories = [...new Set(allPosts.map(post => post.data.category).filter(Boolean))];
const defaultCategories = ['teknoloji', 'oyun', 'dizi-film'];
const mergedCategories = [...new Set([...defaultCategories, ...activeCategories])];

const categoryLabels: Record<string, string> = {
	'teknoloji': 'Teknoloji & Bilim',
	'oyun': 'Oyun',
	'dizi-film': 'Dizi & Film',
	'kuantum-evreni': 'Kuantum Evreni'
};

const getCategoryLabel = (cat: string) => {
	return categoryLabels[cat] || (cat.charAt(0).toUpperCase() + cat.slice(1).replace('-', ' '));
};

// JSON-LD Yapılandırılmış Veri (Schema.org)
const imageUrl = new URL(image, canonicalURL.origin).toString();
const jsonLd = type === 'article' && articleData ? {
	"@context": "https://schema.org",
	"@type": "NewsArticle",
	"mainEntityOfPage": {
		"@type": "WebPage",
		"@id": canonicalURL.toString()
	},
	"headline": title,
	"description": description,
	"image": [
		`${imageUrl}?ratio=16x9`,
		`${imageUrl}?ratio=4x3`,
		`${imageUrl}?ratio=1x1`
	],
	"datePublished": articleData.pubDate.toISOString(),
	"dateModified": articleData.dateModified ? articleData.dateModified.toISOString() : articleData.pubDate.toISOString(),
	"author": {
		"@type": "Person",
		"name": "Teknoloji Editoryal Ekibi",
		"url": new URL("/yazar/editoryal-ekip", canonicalURL.origin).toString(),
		"sameAs": [
			"https://x.com/kaose_dev",
			"https://linkedin.com/company/kaose-dev"
		]
	},
	"publisher": {
		"@type": "Organization",
		"name": siteName,
		"logo": {
			"@type": "ImageObject",
			"url": new URL("/favicon.svg", canonicalURL.origin).toString(),
			"width": 600,
			"height": 60
		}
	}
} : {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": siteName,
	"url": canonicalURL.origin,
	"description": description
};
---

<!doctype html>
<html lang="tr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="canonical" href={canonicalURL} />
		<link rel="alternate" type="application/rss+xml" title={`${siteName} RSS Akışı`} href={new URL('/rss.xml', canonicalURL.origin).toString()} />
		
		<!-- Image Preload for LCP (Largest Contentful Paint) -->
		{type === 'article' && image && (
			<link rel="preload" as="image" href={new URL(image, canonicalURL.origin).toString()} crossorigin="anonymous" />
		)}
		
		<!-- SEO Meta Etiketleri -->
		<title>{title} | {siteName}</title>
		<meta name="title" content={`${title} | ${siteName}`} />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords.join(', ')} />
		
		<!-- Google Keşfet (Discover) İçin Kritik Ayar -->
		<meta name="robots" content="index, follow, max-image-preview:large" />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={type} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={`${title} | ${siteName}`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, canonicalURL)} />
		<meta property="og:site_name" content={siteName} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={`${title} | ${siteName}`} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, canonicalURL)} />

		<!-- JSON-LD Yapılandırılmış Veri Ekleme -->
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

		<!-- Google AdSense / AdMob Otomatik Reklam Entegrasyonu -->
		{adsenseClientId && (
			<script 
				async 
				src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClientId}`} 
				crossorigin="anonymous"
			></script>
		)}
	</head>
	<body>
		<!-- Glow Blur Efektleri (Arka Plan Neon Işıkları) -->
		<div class="glow-blur-purple" style="top: 10%; left: 5%;"></div>
		<div class="glow-blur-cyan" style="top: 40%; right: 5%;"></div>
		<div class="glow-blur-purple" style="bottom: 10%; left: 20%;"></div>

		<div class="site-container">
			<!-- Header / Navbar -->
			<header class="site-header">
				<div class="header-container">
					<!-- Üst Satır: Logo ve Slogan -->
					<div class="header-top-row">
						<div class="logo-container">
							<a href="/" class="logo-link" id="logo">
								<span class="logo-text">{siteName.slice(0, 2)}</span><span>{siteName.slice(2)}</span>
							</a>
							<span class="logo-separator">|</span>
							<span class="logo-slogan">Geleceğin Haberciliği: Otonom kontrol, Özgün İçerik, Teyitli Gerçek.</span>
						</div>
					</div>
					<!-- Alt Satır: Navigasyon ve Arama -->
					<nav class="navbar" id="main-nav">
						<ul class="nav-links">
							<li><a href="/" class="nav-link">Ana Sayfa</a></li>
							{mergedCategories.map(cat => (
								<li><a href={`/kategori/${cat}`} class="nav-link">{getCategoryLabel(cat)}</a></li>
							))}
							<li><a href="/yazar/editoryal-ekip" class="nav-link nav-link-editorial">★ Editörün Kalemi</a></li>
						</ul>
						<div class="nav-search-wrapper">
							<Search />
						</div>
					</nav>
				</div>
			</header>

			<!-- Ana İçerik Alanı -->
			<main class="site-main" id="main-content">
				<slot />
			</main>

			<!-- Footer -->
			<footer class="site-footer">
				<div class="footer-content">
					<div class="footer-brand">
						<a href="/" class="logo-link">
							<span class="logo-text">{siteName.slice(0, 2)}</span><span>{siteName.slice(2)}</span>
						</a>
						<p class="footer-desc">
							Gündemi yapay zekanın gücüyle yakalayın: Teknoloji ve bilim dünyasından gelişmeleri, haberleri MetaKalem doğruluğuyla derleyen otonom haber merkeziniz.
						</p>
					</div>
					<div class="footer-links-group">
						<h4>Kategoriler</h4>
						<ul>
							{mergedCategories.map(cat => (
								<li><a href={`/kategori/${cat}`}>{getCategoryLabel(cat)}</a></li>
							))}
						</ul>
					</div>
					<div class="footer-links-group">
						<h4>Kurumsal</h4>
						<ul>
							<li><a href="/hakkimizda">Hakkımızda</a></li>
							<li><a href="/yazar/editoryal-ekip">Yazarlarımız</a></li>
							<li><a href="/editoryal-ilkeler">Yayın İlkeleri</a></li>
							<li><a href="/iletisim">İletişim</a></li>
							<li><a href="/gizlilik-politikasi">Gizlilik Politikası</a></li>
							<li><a href="/cerez-politikasi">Çerez Politikası</a></li>
						</ul>
					</div>
				</div>
				<div class="footer-bottom">
					<p>&copy; {new Date().getFullYear()} {siteName}. Tüm hakları saklıdır. Bu portal tamamen otonom yapay zeka ajanları tarafından yönetilmektedir.</p>
				</div>
			</footer>
		</div>

		<!-- Çerez Onay Banner'ı (Cookie Consent) -->
		<div id="cookie-consent-banner" class="cookie-banner hidden">
			<div class="cookie-content">
				<p>
					Deneyiminizi optimize etmek, analiz trafiğini izlemek ve kişiselleştirilmiş reklamlar sunmak amacıyla çerezleri kullanıyoruz. 
					Detaylı bilgi için <a href="/cerez-politikasi" class="cookie-link">Çerez Politikamızı</a> inceleyebilirsiniz.
				</p>
				<div class="cookie-buttons">
					<button id="btn-cookie-reject" class="cookie-btn cookie-btn-secondary">Reddet</button>
					<button id="btn-cookie-accept" class="cookie-btn cookie-btn-primary">Kabul Et</button>
				</div>
			</div>
		</div>

		<script is:inline>
			document.addEventListener("DOMContentLoaded", () => {
				const banner = document.getElementById("cookie-consent-banner");
				const acceptBtn = document.getElementById("btn-cookie-accept");
				const rejectBtn = document.getElementById("btn-cookie-reject");

				if (banner && acceptBtn && rejectBtn) {
					const consent = localStorage.getItem("cookie_consent");
					if (!consent) {
						setTimeout(() => {
							banner.classList.remove("hidden");
						}, 1000);
					}

					acceptBtn.addEventListener("click", () => {
						localStorage.setItem("cookie_consent", "accepted");
						banner.classList.add("hidden");
					});

					rejectBtn.addEventListener("click", () => {
						localStorage.setItem("cookie_consent", "rejected");
						banner.classList.add("hidden");
					});
				}
			});
		</script>
	</body>
</html>

<style>
	.site-container {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
		position: relative;
		z-index: 1;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(9, 9, 11, 0.8);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border-color);
	}

	.header-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0.75rem 2rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.header-top-row {
		display: flex;
		justify-content: flex-start;
		align-items: center;
		padding-bottom: 0.5rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
	}

	.navbar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0;
		width: 100%;
	}

	.logo-container {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.logo-separator {
		color: var(--text-muted);
		opacity: 0.4;
	}

	.logo-slogan {
		font-size: 0.8rem;
		color: var(--text-secondary);
		font-weight: 500;
		letter-spacing: 0.01em;
		white-space: nowrap;
	}

	.logo-link {
		font-family: var(--font-display);
		font-size: 1.5rem;
		font-weight: 800;
		text-decoration: none;
		letter-spacing: -0.03em;
		display: flex;
		align-items: center;
		gap: 0.1rem;
	}

	.logo-link span:first-child {
		background: var(--gradient-primary);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}
	.logo-link span:last-child {
		color: #ffffff;
	}

	.nav-links {
		display: flex;
		list-style: none;
		gap: 2rem;
		white-space: nowrap;
	}

	.nav-links li {
		flex-shrink: 0;
	}

	.nav-link {
		color: var(--text-secondary);
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 500;
		transition: var(--transition-smooth);
		position: relative;
		padding: 0.25rem 0;
	}

	.nav-link:hover {
		color: #ffffff;
	}

	.nav-link-editorial {
		background: linear-gradient(135deg, #06b6d4, #8b5cf6);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		font-weight: 700 !important;
		text-shadow: 0 0 10px rgba(139, 92, 246, 0.2);
	}

	.nav-link-editorial::after {
		background: linear-gradient(135deg, #06b6d4, #8b5cf6) !important;
	}

	.nav-link::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 0;
		width: 0;
		height: 2px;
		background: var(--gradient-primary);
		transition: var(--transition-smooth);
	}

	.nav-link:hover::after {
		width: 100%;
	}

	.site-main {
		flex: 1;
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem 2rem 4rem 2rem;
		box-sizing: border-box;
	}

	.site-footer {
		background: #0b0b0d;
		border-top: 1px solid var(--border-color);
		padding: 4rem 2rem 2rem 2rem;
		margin-top: auto;
	}

	.footer-content {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 3rem;
		margin-bottom: 3rem;
	}

	.footer-brand {
		max-width: 400px;
	}

	.footer-desc {
		color: var(--text-muted);
		font-size: 0.9rem;
		margin-top: 1rem;
	}

	.footer-links-group h4 {
		margin-bottom: 1.25rem;
		font-size: 1.1rem;
	}

	.footer-links-group ul {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.footer-links-group a {
		color: var(--text-secondary);
		text-decoration: none;
		font-size: 0.9rem;
		transition: var(--transition-smooth);
	}

	.footer-links-group a:hover {
		color: var(--color-purple);
		padding-left: 4px;
	}

	.footer-bottom {
		max-width: 1200px;
		margin: 0 auto;
		border-top: 1px solid var(--border-color);
		padding-top: 1.5rem;
		text-align: center;
		color: var(--text-muted);
		font-size: 0.8rem;
	}

	@media (max-width: 1024px) {
		.nav-links {
			gap: 1rem;
		}
	}

	@media (max-width: 768px) {
		.header-container {
			padding: 0.75rem 1rem;
			gap: 0.5rem;
		}

		.header-top-row {
			justify-content: center;
			padding-bottom: 0;
			border-bottom: none;
		}

		.logo-slogan, .logo-separator {
			display: none;
		}

		.navbar {
			flex-direction: column;
			gap: 1rem;
			padding: 0.5rem 0;
			width: 100%;
			overflow: hidden;
			align-items: center;
		}

		.logo-container {
			padding: 0;
			justify-content: center;
			width: 100%;
			box-sizing: border-box;
		}

		.nav-links {
			display: flex;
			flex-wrap: nowrap;
			width: 100%;
			max-width: 100%;
			min-width: 0;
			align-self: stretch;
			justify-content: flex-start;
			align-items: center;
			overflow-x: auto;
			white-space: nowrap;
			gap: 1.25rem;
			padding: 0.5rem 1.5rem;
			margin: 0;
			box-sizing: border-box;
			scrollbar-width: none; /* Firefox */
			-ms-overflow-style: none;  /* IE and Edge */
			-webkit-overflow-scrolling: touch; /* Smooth scroll on iOS */
		}

		.nav-links::-webkit-scrollbar {
			display: none; /* Safari and Chrome */
		}

		.nav-links li {
			flex-shrink: 0;
			display: block;
		}

		.nav-link {
			font-size: 0.9rem;
			flex-shrink: 0;
			display: inline-block;
		}

		.footer-content {
			flex-direction: column;
			gap: 2rem;
		}
	}

	/* Çerez Banner Tasarımı */
	.cookie-banner {
		position: fixed;
		bottom: 2rem;
		left: 50%;
		transform: translateX(-50%);
		width: calc(100% - 4rem);
		max-width: 600px;
		background: rgba(18, 18, 22, 0.85);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 16px;
		padding: 1.5rem;
		z-index: 9999;
		box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6), 0 0 20px var(--color-purple-glow);
		transition: opacity 0.5s ease, transform 0.5s ease;
		opacity: 1;
	}

	.cookie-banner.hidden {
		display: none !important;
		opacity: 0;
		transform: translate(-50%, 20px);
		pointer-events: none;
	}

	.cookie-content {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.cookie-content p {
		color: var(--text-secondary);
		font-size: 0.85rem;
		line-height: 1.5;
		margin: 0;
	}

	.cookie-link {
		color: var(--color-cyan);
		text-decoration: underline;
		font-weight: 500;
	}

	.cookie-buttons {
		display: flex;
		justify-content: flex-end;
		gap: 1rem;
	}

	.cookie-btn {
		font-family: var(--font-display);
		font-size: 0.85rem;
		font-weight: 600;
		padding: 0.5rem 1.25rem;
		border-radius: 10px;
		cursor: pointer;
		transition: var(--transition-smooth);
	}

	.cookie-btn-primary {
		background: var(--gradient-primary);
		color: #ffffff;
		border: none;
		box-shadow: 0 0 15px rgba(139, 92, 246, 0.3);
	}

	.cookie-btn-primary:hover {
		box-shadow: 0 0 25px rgba(6, 182, 212, 0.5);
		transform: translateY(-1px);
	}

	.cookie-btn-secondary {
		background: transparent;
		color: var(--text-secondary);
		border: 1px solid var(--border-color);
	}

	.cookie-btn-secondary:hover {
		color: #ffffff;
		border-color: rgba(255, 255, 255, 0.2);
		background: rgba(255, 255, 255, 0.03);
	}

	@media (max-width: 600px) {
		.cookie-banner {
			bottom: 1rem;
			width: calc(100% - 2rem);
			padding: 1rem;
		}
		.cookie-buttons {
			width: 100%;
			flex-direction: row;
		}
		.cookie-btn {
			flex: 1;
			text-align: center;
		}
	}
</style>
